# Beaver Docker and self-hosting configuration.
#
# Copy this file to .env, then set a unique APP_KEY:
#   docker compose run --rm app php artisan key:generate --show
# Paste the printed value below, review the passwords, and run:
#   docker compose up -d --build

# --- Application ---
APP_NAME=Kollek
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

# Host port the web container is published on (maps to port 80 inside).
APP_PORT=8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Database (MySQL service) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=beaver
DB_USERNAME=beaver
DB_PASSWORD=change-me-please
# Used by the MySQL container for the root account and its health check.
DB_ROOT_PASSWORD=change-me-too

# Set to false to manage migrations yourself instead of on container start.
RUN_MIGRATIONS=true

# --- Sessions / cache / queue (database-backed by default; no extra service) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database
CACHE_STORE=database

# Full page cache for the public marketing site and docs (7 day lifetime).
# The response cache is cleared automatically on every deploy (entrypoint).
RESPONSE_CACHE_ENABLED=true

# --- Filesystem (uploaded item photos) ---
FILESYSTEM_DISK=local

# --- Mail ---
# Replace with your SMTP or Resend credentials to send real email.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="Kollek"

# --- Misc ---
ACCOUNT_DELETION_NOTIFICATION_EMAIL="hello@example.com"

# How many days deleted objects stay in the trash before the scheduler purges them.
TRASH_RETENTION_DAYS=30

# --- Marketing site ---
# Set to true to serve the public marketing site (homepage and API reference).
SHOW_MARKETING_SITE=false
